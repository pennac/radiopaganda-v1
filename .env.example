# ── Google tag / Tag Manager ────────────────────────────────────
# Accetta sia un container GTM classico (GTM-XXXXXXX, da tagmanager.google.com)
# sia un Google tag (GT-XXXXXXXX) o un Measurement ID GA4 diretto (G-XXXXXXXXXX)
# — il formato viene rilevato automaticamente dal prefisso (vedi utils/gtm.js).
GTM_ID=GT-XXXXXXXX

# ── Plausible Analytics ─────────────────────────────────────────
# Il dominio del sito come registrato su plausible.io
PLAUSIBLE_DOMAIN=radiopaganda.com

# ── Beehiiv Newsletter ──────────────────────────────────────────
# Ottieni su app.beehiiv.com → Settings → API
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxx

# ── Sito ────────────────────────────────────────────────────────
SITE_URL=https://radiopaganda.com
